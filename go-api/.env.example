# Copy to .env and fill in real values before running locally.
# Never commit the actual .env file.

# Shared JWT signing secret — must match the value used by node-api.
JWT_SECRET=replace-with-a-long-random-string

# URL of the Node.js stats API (use http://node-api:3000 in Docker, http://localhost:3000 locally).
NODE_API_URL=http://localhost:3000

# Demo credentials for the /api/v1/auth/login endpoint.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# HTTP port the Go API listens on.
PORT=8080
