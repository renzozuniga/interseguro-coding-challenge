# No secrets live in the frontend — everything sensitive stays server-side.
# This file is a placeholder so the frontend directory follows the same
# convention as the other services.

# In development, Vite proxies /api to VITE_API_BASE_URL (see vite.config.js).
# In production (Docker), nginx handles the proxy — no env var needed.
VITE_API_BASE_URL=http://localhost:8080
